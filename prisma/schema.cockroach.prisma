datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-cockroach"
}

// ----------------------------------------------------
// ENUMS
// ----------------------------------------------------

enum LifeCycleStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum WorkflowStatus {
  DRAFT
  VALIDATED
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ImportStatus {
  UPLOADED
  VALIDATING
  VALIDATED
  PARTIALLY_IMPORTED
  IMPORTED
  FAILED
}

enum ImportType {
  CODE_LIST
  OBSERVATIONS
  DATAFLOWS
  DSD
  CONCEPTS
}

enum Severity {
  ERROR
  WARNING
}

enum ComponentType {
  DIMENSION
  TIME_DIMENSION
  MEASURE
  ATTRIBUTE
  METADATA
}

enum ConceptType {
  DIMENSION
  ATTRIBUTE
  MEASURE
  METADATA
}

enum AttachmentLevel {
  OBSERVATION
  SERIES
  DATASET
}

enum PageType {
  INDICATOR
  ECONOMY
  DATAFLOW
}

enum VisualizationType {
  TABLE
  LINE_CHART
  BAR_CHART
  MAP
}

enum ConversionMethod {
  MULTIPLIER_ONLY
  CURRENCY_CONVERSION
  WARNING_ONLY
  NONE
}

enum EconomyType {
  COUNTRY
  REGION
  SUBREGION
  GROUP
}

enum ChangeType {
  CREATE
  UPDATE
  DELETE
  RESTORE
  STATUS_CHANGE
  PUBLISH
  UNPUBLISH
}

enum AggregationMethod {
  SUM
  AVERAGE
  WEIGHTED_AVERAGE
}

enum ValueType {
  REPORTED
  CALCULATED
  AGGREGATED
}

enum WeightType {
  GDP
  POPULATION
  TRADE
  CUSTOM
}

// ----------------------------------------------------
// MODELS
// ----------------------------------------------------

model Dataset {
  id               String    @id @default(uuid())
  code             String    @unique
  name             String   
  description      String?  
  divisionCode     String    @map("division_code")
  agencyCode       String    @default("ADB") @map("agency_code")
  status           LifeCycleStatus @default(ACTIVE)
  defaultFrequency String[]  @default([]) @map("default_frequency")
  sortOrder        Int       @default(0) @map("sort_order")
  dsdCode          String?   @map("dsd_code")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  agency                   Agency                     @relation(fields: [agencyCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  dsd                      Dsd?                       @relation(fields: [dsdCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  dataflows                Dataflow[]
  codeLists                CodeList[]
  indicatorDatasetMetadata IndicatorDatasetMetadata[]
  indicatorDataflowMapping IndicatorDataflowMapping[]
  datasetDimensions        DatasetDimension[]
  datasetAttributes        DatasetAttribute[]
  constraints              Constraint[]
  observations             Observation[]
  harmonizationRules       HarmonizationRule[]
  pageConfigs              PageConfig[]
  regionalWeights          RegionalWeight[]
  importBatches            ImportBatch[]
  aggregationRules         AggregationRule[]
  frontEndCategoryIndicators FrontEndCategoryIndicator[]

  @@map("datasets")
}

model Dsd {
  id          String         @id @default(uuid())
  code        String         @unique
  agency      String        
  version     String        
  name        String        
  description String?       
  urn         String?       
  status      LifeCycleStatus @default(ACTIVE)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")
  components  DsdComponent[]
  dataflows   Dataflow[]
  datasets    Dataset[]

  @@map("dsds")
}

model DsdComponent {
  id              String           @id @default(uuid())
  dsdCode         String           @map("dsd_code")
  componentCode   String           @map("component_code")
  componentType   ComponentType    @map("component_type")
  conceptCode     String           @map("concept_code")
  codeListCode    String?          @map("code_list_code")
  position        Int?
  isRequired      Boolean          @default(false) @map("is_required")
  attachmentLevel AttachmentLevel? @map("attachment_level")
  textType        String?          @map("text_type")
  defaultValue    String?          @map("default_value")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  dsd      Dsd       @relation(fields: [dsdCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  concept  Concept   @relation(fields: [conceptCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  codeList CodeList? @relation(fields: [codeListCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([dsdCode, componentCode])
  @@map("dsd_components")
}

model ConceptScheme {
  id          String    @id @default(uuid())
  code        String    @unique
  agency      String   
  version     String   
  name        String   
  description String?  
  urn         String?  
  status      LifeCycleStatus @default(ACTIVE)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  concepts    Concept[]

  @@map("concept_schemes")
}

model Concept {
  id                         String                      @id @default(uuid())
  conceptSchemeCode          String                      @map("concept_scheme_code")
  code                       String                      @unique
  name                       String                     
  description                String?                    
  codeListCode               String?                     @map("code_list_code")
  conceptType                ConceptType?                @map("concept_type")
  dataType                   String?                     @map("data_type")
  defaultRole                String?                     @map("default_role")
  isCoded                    Boolean                     @default(false) @map("is_coded")
  status                     LifeCycleStatus             @default(ACTIVE)
  urn                        String?                    
  createdAt                  DateTime                    @default(now()) @map("created_at")
  updatedAt                  DateTime                    @updatedAt @map("updated_at")
  deletedAt                  DateTime?                   @map("deleted_at")
  conceptScheme              ConceptScheme               @relation(fields: [conceptSchemeCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  codeList                   CodeList?                   @relation(fields: [codeListCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  dsdComponents              DsdComponent[]
  datasetDimensions          DatasetDimension[]
  datasetAttributes          DatasetAttribute[]
  dataflowDimensions         DataflowDimension[]
  dataflowAttributes         DataflowAttribute[]
  observationExtraDimensions ObservationExtraDimension[]
  observationAttributes      ObservationAttribute[]
  constraintItems            ConstraintItem[]

  @@map("concepts")
}

model Dataflow {
  id               String        @id @default(uuid())
  code             String       
  datasetCode      String        @map("dataset_code")
  name             String       
  description      String?      
  dataflowLevel    Int           @default(1) @map("dataflow_level")
  mainDataflowCode String?       @map("main_dataflow_code")
  parentCode       String?       @map("parent_code")
  dsdCode          String?       @map("dsd_code")
  sortOrder        Int           @default(0) @map("sort_order")
  status           LifeCycleStatus @default(ACTIVE)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  dataset            Dataset    @relation(fields: [datasetCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  dsd                Dsd?       @relation(fields: [dsdCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  mainDataflow       Dataflow?  @relation("MainToSecondaryDataflow", fields: [datasetCode, mainDataflowCode], references: [datasetCode, code], onDelete: Restrict, onUpdate: Cascade)
  secondaryDataflows Dataflow[] @relation("MainToSecondaryDataflow")

  parent   Dataflow?  @relation("DataflowParent", fields: [datasetCode, parentCode], references: [datasetCode, code], onDelete: Restrict, onUpdate: Cascade)
  children Dataflow[] @relation("DataflowParent")

  indicatorDataflowMappingMain IndicatorDataflowMapping[] @relation("MainDataflowMapping")
  indicatorDataflowMappingSec  IndicatorDataflowMapping[] @relation("SecondaryDataflowMapping")
  dataflowDimensions           DataflowDimension[]
  dataflowAttributes           DataflowAttribute[]
  constraints                  Constraint[]
  observationsMain             Observation[]              @relation("MainDataflowObs")
  observationsSec              Observation[]              @relation("SecondaryDataflowObs")
  harmonizationRules           HarmonizationRule[]
  pageConfigDataflows          PageConfigDataflow[]
  dataflowIndicators           DataflowIndicator[]
  frontEndCategoryIndicators   FrontEndCategoryIndicator[]

  @@unique([datasetCode, code])
  @@map("dataflows")
}

model CodeList {
  id                 String    @id @default(uuid())
  code               String    @unique
  name               String   
  description        String?  
  datasetCode        String?   @map("dataset_code")
  isGlobal           Boolean   @default(true) @map("is_global")
  agencyCode         String    @default("ADB") @map("agency_code")
  relatedConceptCode String?   @map("related_concept_code")
  version            String?  
  isHierarchical     Boolean   @default(false) @map("is_hierarchical")
  status             LifeCycleStatus @default(ACTIVE)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  dataset Dataset? @relation(fields: [datasetCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  agency  Agency   @relation(fields: [agencyCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  codeListItems      CodeListItem[]
  concepts           Concept[]
  dsdComponents      DsdComponent[]
  datasetDimensions  DatasetDimension[]
  datasetAttributes  DatasetAttribute[]
  dataflowDimensions DataflowDimension[]
  dataflowAttributes DataflowAttribute[]
  frontEndCategoryIndicators FrontEndCategoryIndicator[]

  @@map("code_lists")
}

model CodeListItem {
  id             String    @id @default(uuid())
  codeListCode   String    @map("code_list_code")
  itemCode       String    @map("item_code")
  itemName       String    @map("item_name")
  description    String?  
  parentItemCode String?   @map("parent_item_code")
  sortOrder      Int       @default(0) @map("sort_order")
  isActive       Boolean   @default(true) @map("is_active")
  validFrom      String?   @map("valid_from")
  validTo        String?   @map("valid_to")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  codeList   CodeList       @relation(fields: [codeListCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  parentItem CodeListItem?  @relation("Hierarchy", fields: [codeListCode, parentItemCode], references: [codeListCode, itemCode], onDelete: Restrict, onUpdate: Cascade)
  childItems CodeListItem[] @relation("Hierarchy")
  frontEndCategoryIndicators FrontEndCategoryIndicator[]

  @@unique([codeListCode, itemCode])
  @@map("code_list_items")
}

model Indicator {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String   
  description String?  
  themeCode   String?   @map("theme_code")
  shortName   String?   @map("short_name")
  definition  String?  
  defaultUnitCode String? @map("default_unit_code")
  defaultUnitMultCode String? @map("default_unit_mult_code")
  defaultFreqCode String? @map("default_freq_code")
  source      String?  
  methodology String?  
  category    String?  
  sortOrder   Int       @default(0) @map("sort_order")
  status      LifeCycleStatus @default(ACTIVE)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  indicatorDatasetMetadata IndicatorDatasetMetadata[]
  indicatorDataflowMapping IndicatorDataflowMapping[]
  observations             Observation[]
  calculatedIndicator      CalculatedIndicator?
  indicatorThemeMapping    IndicatorThemeMapping[]
  aggregationRules         AggregationRule[]          @relation("TargetIndicator")
  aggregationRulesWeight   AggregationRule[]          @relation("WeightIndicator")
  indicatorFormulas        IndicatorFormula[]
  harmonizationRules       HarmonizationRule[]
  dataflowIndicators       DataflowIndicator[]
  constraints              Constraint[]

  @@map("indicators")
}

model IndicatorDatasetMetadata {
  id            String  @id @default(uuid())
  datasetCode   String  @map("dataset_code")
  indicatorCode String  @map("indicator_code")
  divisionCode  String? @map("division_code")

  name        String?  
  description String?  
  sourceNotes String?   @map("source_notes")
  methodology String?  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  dataset   Dataset   @relation(fields: [datasetCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  indicator Indicator @relation(fields: [indicatorCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@map("indicator_dataset_metadata")
}

model Economy {
  id            String       @id @default(uuid())
  code          String       @unique
  name          String      
  description   String?     
  parentCode    String?      @map("parent_code")
  sortOrder     Int?         @map("sort_order")
  economyType   EconomyType? @map("economy_type")
  iso2Code      String?      @map("iso2_code")
  iso3Code      String?      @map("iso3_code")
  currencyCode  String?      @map("currency_code")
  regionCode    String?      @map("region_code")
  subregionCode String?      @map("subregion_code")
  displayOrder  Int?         @map("display_order")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  parent                 Economy?                @relation("Hierarchy", fields: [parentCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  children               Economy[]               @relation("Hierarchy")
  currency               Currency?               @relation(fields: [currencyCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  observations           Observation[]
  harmonizationRuleItems HarmonizationRuleItem[]
  pageConfigEconomies    PageConfigEconomy[]
  regionalDefGroups      RegionalDefinition[]    @relation("GroupEconomy")
  regionalDefMembers     RegionalDefinition[]    @relation("MemberEconomy")
  regionalWeightsGroups  RegionalWeight[]        @relation("GroupEconomyWeights")
  regionalWeightsMembers RegionalWeight[]        @relation("MemberEconomyWeights")

  @@map("economies")
}

model Currency {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String   
  symbol        String?  
  decimalPlaces Int       @default(2) @map("decimal_places")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  economies           Economy[]
  exchangeRatesSource CurrencyExchangeRate[] @relation("SourceCurrency")
  exchangeRatesTarget CurrencyExchangeRate[] @relation("TargetCurrency")

  @@map("currencies")
}

model Theme {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String   
  description String?  
  parentCode  String?   @map("parent_code")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  parent                Theme?                  @relation("Hierarchy", fields: [parentCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  children              Theme[]                 @relation("Hierarchy")
  indicatorThemeMapping IndicatorThemeMapping[]

  @@map("themes")
}

model IndicatorThemeMapping {
  id            String    @id @default(uuid())
  indicatorCode String    @map("indicator_code")
  themeCode     String    @map("theme_code")
  createdAt     DateTime  @default(now()) @map("created_at")
  indicator     Indicator @relation(fields: [indicatorCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  theme         Theme     @relation(fields: [themeCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([indicatorCode, themeCode])
  @@map("indicator_theme_mapping")
}

model DatasetDimension {
  id           String   @id @default(uuid())
  datasetCode  String   @map("dataset_code")
  conceptCode  String   @map("concept_code")
  codeListCode String?  @map("code_list_code")
  position     Int
  isRequired   Boolean  @map("is_required")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dataset  Dataset   @relation(fields: [datasetCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  concept  Concept   @relation(fields: [conceptCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  codeList CodeList? @relation(fields: [codeListCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([datasetCode, conceptCode])
  @@map("dataset_dimensions")
}

model DatasetAttribute {
  id              String          @id @default(uuid())
  datasetCode     String          @map("dataset_code")
  conceptCode     String          @map("concept_code")
  codeListCode    String?         @map("code_list_code")
  isRequired      Boolean         @map("is_required")
  attachmentLevel AttachmentLevel @map("attachment_level")
  defaultValue    String?         @map("default_value")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  dataset  Dataset   @relation(fields: [datasetCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  concept  Concept   @relation(fields: [conceptCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  codeList CodeList? @relation(fields: [codeListCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([datasetCode, conceptCode])
  @@map("dataset_attributes")
}

model DataflowDimension {
  id           String    @id @default(uuid())
  dataflowCode String    @map("dataflow_code")
  datasetCode  String    @map("dataset_code")
  conceptCode  String    @map("concept_code")
  codeListCode String?   @map("code_list_code")
  position     Int?
  isRequired   Boolean   @default(true) @map("is_required")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  dataflow Dataflow  @relation(fields: [datasetCode, dataflowCode], references: [datasetCode, code], onDelete: Restrict, onUpdate: Cascade)
  concept  Concept   @relation(fields: [conceptCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  codeList CodeList? @relation(fields: [codeListCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([datasetCode, dataflowCode, conceptCode])
  @@map("dataflow_dimensions")
}

model DataflowAttribute {
  id              String          @id @default(uuid())
  dataflowCode    String          @map("dataflow_code")
  datasetCode     String          @map("dataset_code")
  conceptCode     String          @map("concept_code")
  codeListCode    String?         @map("code_list_code")
  isRequired      Boolean         @default(false) @map("is_required")
  attachmentLevel AttachmentLevel @map("attachment_level")
  isActive        Boolean         @default(true) @map("is_active")
  defaultValue    String?         @map("default_value")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  dataflow Dataflow  @relation(fields: [datasetCode, dataflowCode], references: [datasetCode, code], onDelete: Restrict, onUpdate: Cascade)
  concept  Concept   @relation(fields: [conceptCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  codeList CodeList? @relation(fields: [codeListCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([datasetCode, dataflowCode, conceptCode])
  @@map("dataflow_attributes")
}

model IndicatorDataflowMapping {
  id                    String    @id @default(uuid())
  datasetCode           String    @map("dataset_code")
  indicatorCode         String    @map("indicator_code")
  mainDataflowCode      String    @map("main_dataflow_code")
  secondaryDataflowCode String?   @map("secondary_dataflow_code")
  sortOrder             Int?      @map("sort_order")
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  dataset           Dataset   @relation(fields: [datasetCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  indicator         Indicator @relation(fields: [indicatorCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  mainDataflow      Dataflow  @relation("MainDataflowMapping", fields: [datasetCode, mainDataflowCode], references: [datasetCode, code], onDelete: Restrict, onUpdate: Cascade)
  secondaryDataflow Dataflow? @relation("SecondaryDataflowMapping", fields: [datasetCode, secondaryDataflowCode], references: [datasetCode, code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([datasetCode, indicatorCode, mainDataflowCode, secondaryDataflowCode])
  @@map("indicator_dataflow_mapping")
}

model Observation {
  id                    String   @id @default(uuid())
  datasetCode           String   @map("dataset_code")
  mainDataflowCode      String   @map("main_dataflow_code")
  secondaryDataflowCode String?  @map("secondary_dataflow_code")
  indicatorCode         String   @map("indicator_code")
  economyCode           String   @map("economy_code")
  period                String  
  freqCode              String   @map("freq_code")
  obsValue              Decimal? @map("obs_value")
  unitCode              String?  @map("unit_code")
  unitMultCode          String?  @map("unit_mult_code")
  decimalsCode          String?  @map("decimals_code")
  obsStatusCode         String?  @map("obs_status_code")
  refYear               String?  @map("ref_year")
  baseYear              String?  @map("base_year")
  dataSource            String?  @map("data_source")
  methodology           String? 
  footnote              String? 
  divisionCode          String?  @map("division_code")
  agencyCode            String   @default("ADB") @map("agency_code")
  sexCode               String?  @map("sex_code")
  ageCode               String?  @map("age_code")
  sectorCode            String?  @map("sector_code")
  occupationCode        String?  @map("occupation_code")
  regionCode            String?  @map("region_code")
  sizeClassCode         String?  @map("size_class_code")
  ownershipCode         String?  @map("ownership_code")
  currencyCode          String?  @map("currency_code")
  adjustmentCode        String?  @map("adjustment_code")
  priceBaseCode         String?  @map("price_base_code")
  counterpartAreaCode   String?  @map("counterpart_area_code")

  workflowStatus           WorkflowStatus @default(DRAFT) @map("workflow_status")
  isPublished              Boolean        @default(false) @map("is_published")
  publishedAt              DateTime?      @map("published_at")
  importBatchId            String?        @map("import_batch_id")
  sourceFileName           String?        @map("source_file_name")
  observationHash          String         @map("observation_hash")
  valueType                ValueType      @default(REPORTED) @map("value_type")
  harmonizedValue          Decimal?       @map("harmonized_value")
  harmonizedUnitCode       String?        @map("harmonized_unit_code")
  harmonizedMultiplierCode String?        @map("harmonized_multiplier_code")
  createdBy                String?        @map("created_by")
  updatedBy                String?        @map("updated_by")
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")
  deletedAt                DateTime?      @map("deleted_at")

  dataset           Dataset      @relation(fields: [datasetCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  indicator         Indicator    @relation(fields: [indicatorCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  economy           Economy      @relation(fields: [economyCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  mainDataflow      Dataflow     @relation("MainDataflowObs", fields: [datasetCode, mainDataflowCode], references: [datasetCode, code], onDelete: Restrict, onUpdate: Cascade)
  secondaryDataflow Dataflow?    @relation("SecondaryDataflowObs", fields: [datasetCode, secondaryDataflowCode], references: [datasetCode, code], onDelete: Restrict, onUpdate: Cascade)
  importBatch       ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  agency            Agency       @relation(fields: [agencyCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  unit           CommonUnit?       @relation("ObsUnit", fields: [unitCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  harmonizedUnit CommonUnit?       @relation("ObsHarmUnit", fields: [harmonizedUnitCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  multiplier     CommonMultiplier? @relation("ObsMult", fields: [unitMultCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  harmonizedMult CommonMultiplier? @relation("ObsHarmMult", fields: [harmonizedMultiplierCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  extraDimensions    ObservationExtraDimension[]
  attributes         ObservationAttribute[]
  observationHistory ObservationHistory[]

  // Optimized composite indexes for public data explorer query patterns
  @@index([datasetCode, indicatorCode, economyCode, period, isPublished])
  @@index([datasetCode, economyCode, indicatorCode, period, isPublished])
  @@map("observations")
}

model ObservationExtraDimension {
  id            String   @id @default(uuid())
  observationId String   @map("observation_id")
  conceptCode   String   @map("concept_code")
  codeValue     String   @map("code_value")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  observation Observation @relation(fields: [observationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  concept     Concept     @relation(fields: [conceptCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([observationId, conceptCode])
  @@map("observation_extra_dimensions")
}

model ObservationAttribute {
  id            String   @id @default(uuid())
  observationId String   @map("observation_id")
  conceptCode   String   @map("concept_code")
  value         String? 
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  observation Observation @relation(fields: [observationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  concept     Concept     @relation(fields: [conceptCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@unique([observationId, conceptCode])
  @@map("observation_attributes")
}

model ObservationHistory {
  id             String     @id @default(uuid())
  observationId  String     @map("observation_id")
  changeType     ChangeType @map("change_type")
  fieldName      String?    @map("field_name")
  oldValue       String?    @map("old_value")
  newValue       String?    @map("new_value")
  reason         String?   
  sourceFileName String?    @map("source_file_name")
  importBatchId  String?    @map("import_batch_id")
  changedBy      String?    @map("changed_by")
  changedAt      DateTime   @default(now()) @map("changed_at")

  observation Observation  @relation(fields: [observationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("observation_history")
}

model ImportBatch {
  id          String       @id @default(uuid())
  datasetCode String?      @map("dataset_code")
  importType  ImportType   @map("import_type")
  fileName    String       @map("file_name")
  fileHash    String?      @map("file_hash")
  status      ImportStatus @default(UPLOADED) @map("status")
  totalRows   Int          @default(0) @map("total_rows")
  validRows   Int          @default(0) @map("valid_rows")
  invalidRows Int          @default(0) @map("invalid_rows")
  warningRows Int          @default(0) @map("warning_rows")
  uploadedBy  String?      @map("uploaded_by")
  uploadedAt  DateTime     @default(now()) @map("uploaded_at")
  completedAt DateTime?    @map("completed_at")

  dataset Dataset? @relation(fields: [datasetCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

