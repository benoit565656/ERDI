  @@map("import_batches")
}

model ImportValidationMessage {
  id              String   @id @default(uuid())
  importBatchId   String   @map("import_batch_id")
  rowNumber       Int?     @map("row_number")
  severity        Severity
  fieldName       String?  @map("field_name")
  message         String  
  rawRow          Json?    @map("raw_row")
  observationHash String?  @map("observation_hash")
  createdAt       DateTime @default(now()) @map("created_at")

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("import_validation_messages")
}

enum ConstraintScopeType {
  DATASET
  DATAFLOW
  INDICATOR
  DATAFLOW_INDICATOR
}

enum ConstraintRuleType {
  ALLOWED
  FORBIDDEN
  REQUIRED
}

model Constraint {
  id            String              @id @default(uuid())
  scopeType     ConstraintScopeType @map("scope_type")
  datasetCode   String              @map("dataset_code")
  dataflowCode  String?             @map("dataflow_code")
  indicatorCode String?             @map("indicator_code")
  name          String             
  description   String?            
  isActive      Boolean             @default(true) @map("is_active")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?           @map("deleted_at")

  dataset   Dataset    @relation(fields: [datasetCode], references: [code], onDelete: Cascade, onUpdate: Cascade)
  dataflow  Dataflow?  @relation(fields: [datasetCode, dataflowCode], references: [datasetCode, code], onDelete: Cascade, onUpdate: Cascade)
  indicator Indicator? @relation(fields: [indicatorCode], references: [code], onDelete: Cascade, onUpdate: Cascade)

  constraintItems ConstraintItem[]

  @@map("constraints")
}

model ConstraintItem {
  id           String             @id @default(uuid())
  constraintId String             @map("constraint_id")
  conceptCode  String             @map("concept_code")
  ruleType     ConstraintRuleType @map("rule_type")
  codeValue    String?            @map("code_value")
  createdAt    DateTime           @default(now()) @map("created_at")

  constraint Constraint @relation(fields: [constraintId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  concept    Concept    @relation(fields: [conceptCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@map("constraint_items")
}

model CommonUnit {
