  targetUnit CommonUnit?       @relation("HarmRuleItemTrgUnit", fields: [targetUnitCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  sourceMult CommonMultiplier? @relation("HarmRuleItemSrcMult", fields: [sourceMultiplierCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  targetMult CommonMultiplier? @relation("HarmRuleItemTrgMult", fields: [targetMultiplierCode], references: [code], onDelete: Restrict, onUpdate: Cascade)

  @@map("harmonization_rule_items")
}

