}

model HarmonizationRule {
  id                   String           @id @default(uuid())
  datasetCode          String           @map("dataset_code")
  dataflowCode         String?          @map("dataflow_code")
  indicatorCode        String           @map("indicator_code")
  ruleName             String           @map("rule_name")
  targetUnitCode       String?          @map("target_unit_code")
  targetMultiplierCode String?          @map("target_multiplier_code")
  conversionMethod     ConversionMethod @map("conversion_method")
  exchangeRateSource   String?          @map("exchange_rate_source")
  isActive             Boolean          @default(true) @map("is_active")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  deletedAt            DateTime?        @map("deleted_at")

  dataset          Dataset           @relation(fields: [datasetCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  indicator        Indicator         @relation(fields: [indicatorCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  targetUnit       CommonUnit?       @relation(fields: [targetUnitCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  targetMultiplier CommonMultiplier? @relation(fields: [targetMultiplierCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  dataflow         Dataflow?         @relation(fields: [datasetCode, dataflowCode], references: [datasetCode, code], onDelete: Restrict, onUpdate: Cascade)

  ruleItems HarmonizationRuleItem[]

  @@map("harmonization_rules")
}

model HarmonizationRuleItem {
  id                   String   @id @default(uuid())
  harmonizationRuleId  String   @map("harmonization_rule_id")
  economyCode          String?  @map("economy_code")
  sourceUnitCode       String?  @map("source_unit_code")
  sourceMultiplierCode String?  @map("source_multiplier_code")
  targetUnitCode       String?  @map("target_unit_code")
  targetMultiplierCode String?  @map("target_multiplier_code")
  createdAt            DateTime @default(now()) @map("created_at")

  rule       HarmonizationRule @relation(fields: [harmonizationRuleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
