  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  observationsUnit          Observation[]           @relation("ObsUnit")
  observationsHarm          Observation[]           @relation("ObsHarmUnit")
  harmonizationRules        HarmonizationRule[]
  harmonizationRuleItemsSrc HarmonizationRuleItem[] @relation("HarmRuleItemSrcUnit")
  harmonizationRuleItemsTrg HarmonizationRuleItem[] @relation("HarmRuleItemTrgUnit")
  pageConfigs               PageConfig[]

  @@map("common_units")
}

model CommonMultiplier {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String   
